#!/usr/bin/env bash
# bd-package-check - validate the whole better-dev package before install or release.
#
# Lints every skill (frontmatter minimal + name==folder + "Use when" description + no @-links + calm
# voice), runs every helper's selftest, validates the JSON manifests, and checks that backtick-wrapped
# /skill references resolve (to a shipped skill or a known host-optional builtin). Non-zero exit on any
# failure - a release / CI gate, and what `/self-extension` runs before promoting a freshly authored skill.
set -uo pipefail

# Package root = the dir holding skills/ + scripts/ (run from anywhere in the dev repo).
ROOT="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)"
[ -d "$ROOT/skills" ] || ROOT="$(pwd)"
cd "$ROOT"

fail=0
ok()  { printf '  \033[32m✓\033[0m %s\n' "$*"; }
bad() { printf '  \033[31m✗\033[0m %s\n' "$*"; fail=1; }

# /refs a skill may compose from the host but better-dev does not ship.
HOST_OPTIONAL="code-review security-review verify domain-modeling"

# SKILL body with frontmatter, fenced code, inline code, and quoted spans removed - so a backticked
# `@AGENTS.md` or a quoted "MUST" (naming a token to forbid it) doesn't read as a real violation.
prose_of() {
  awk 'NR==1&&$0=="---"{f=1;next} f&&$0=="---"{f=0;b=1;next} b{print}' "$1" \
    | awk '/^```/{c=!c;next} !c{print}' \
    | sed 's/`[^`]*`//g; s/"[^"]*"//g'
}

echo "== skills =="
for f in skills/*/SKILL.md; do
  [ -f "$f" ] || continue
  dir="$(basename "$(dirname "$f")")"
  fm="$(awk 'NR==1&&$0=="---"{f=1;next} f&&$0=="---"{exit} f{print}' "$f")"
  name="$(printf '%s\n' "$fm" | awk -F': *' '/^name:/{print $2; exit}')"
  desc="$(printf '%s\n' "$fm" | sed -n 's/^description: *//p' | head -1)"
  prose="$(prose_of "$f")"
  errs=""
  [ "$name" = "$dir" ] || errs="$errs name!=dir($name)"
  [ -n "$desc" ] || errs="$errs no-description"
  case "$desc" in "Use when"*) ;; *) errs="$errs desc-not-'Use when'";; esac
  ah="$(printf '%s\n' "$fm" | sed -n 's/^argument-hint: *//p' | head -1)"
  case "$ah" in ""|\"*|\'*) ;; \[*|\{*) errs="$errs argument-hint-must-be-a-quoted-string" ;; esac
  printf '%s' "$prose" | grep -qE '(^|[^A-Za-z0-9])@[A-Za-z0-9_./-]+\.(md|sh)' && errs="$errs @-link"
  printf '%s' "$prose" | grep -qE '\b(MUST|ALWAYS|STOP|CRITICAL|SHALL)\b' && errs="$errs shouting"
  [ -z "$errs" ] && ok "$dir" || bad "$dir:$errs"
done

echo "== helper scripts (selftest) =="
for s in scripts/bd-*; do
  [ "$(basename "$s")" = "bd-package-check" ] && continue
  b="$(basename "$s")"
  [ -x "$s" ] || { bad "$b not executable"; continue; }
  "$s" selftest >/dev/null 2>&1 && ok "$b" || bad "$b selftest FAILED"
done

echo "== hook scripts (selftest) =="
for s in hooks/bd-*; do
  [ -e "$s" ] || continue
  b="$(basename "$s")"
  [ -x "$s" ] && "$s" selftest >/dev/null 2>&1 && ok "$b" || bad "$b selftest FAILED"
done

echo "== manifests (valid JSON) =="
for j in .claude-plugin/plugin.json hooks/hooks.json; do
  [ -f "$j" ] || { bad "$j missing"; continue; }
  jq -e . "$j" >/dev/null 2>&1 && ok "$j" || bad "$j invalid JSON"
done

# Informational only: a backtick `/word` is used for real skill invocations, but also for illustrative
# examples, placeholders (`/name`), URL paths (`/dashboard`), and flow names (`/learn`) - too ambiguous to
# gate on. Surface unknowns for a human glance; don't fail the build.
echo "== cross-skill /refs (informational) =="
present="$(ls skills/ 2>/dev/null | tr '\n' ' ')"
unknown=""
for ref in $(grep -rhoE '`/[a-z][a-z-]+`' skills/*/SKILL.md 2>/dev/null | tr -d '`/' | sort -u); do
  case " $present $HOST_OPTIONAL " in *" $ref "*) ;; *) unknown="$unknown $ref" ;; esac
done
[ -z "$unknown" ] && ok "every backtick /ref is a shipped or host-optional skill" \
  || printf '  \033[33m•\033[0m illustrative/placeholder /refs (not gated):%s\n' "$unknown"

echo "== em/en dash gate =="
# Standing repo rule: no em (U+2014) or en (U+2013) dashes in shipped text. Match the raw UTF-8 bytes
# under LC_ALL=C so this holds on BSD grep (no -P) as well as GNU. Covers the shipped surfaces.
em="$(printf '\342\200\224')"; en="$(printf '\342\200\223')"
dash_hits=""
for f in $(find skills scripts docs hooks -type f 2>/dev/null; ls install.sh README.md BOOTSTRAP.md 2>/dev/null); do
  LC_ALL=C grep -lq -e "$em" -e "$en" "$f" 2>/dev/null && dash_hits="$dash_hits $f"
done
[ -z "$dash_hits" ] && ok "no em/en dashes in shipped text" || bad "em/en dash in:$dash_hits"

echo "== manifest version =="
v="$(jq -r '.version // empty' .claude-plugin/plugin.json 2>/dev/null)"
[ -n "$v" ] && ok "plugin.json version present ($v)" || bad "plugin.json has no non-empty version"

echo "== entry-skill utterances =="
# Each entry skill's description should carry at least one phrase a real user would type for that need,
# so natural-language activation routes without a skill name. Any-of match, case-insensitive.
utt() {
  sk="$1"; shift
  d="$(sed -n 's/^description: *//p' "skills/$sk/SKILL.md" 2>/dev/null | head -1 | tr 'A-Z' 'a-z')"
  for p in "$@"; do case "$d" in *"$p"*) return 0 ;; esac; done
  bad "entry skill '$sk': description names no canonical user phrasing (want one of: $*)"
}
utt plan-grill    "feature" "build" "new feature"
utt diagnose      "bug" "broken" "failing" "crash" "flaky" "slow" "regression"
utt groundwork    "greenfield" "new project" "from scratch" "foundation"
utt pr-and-verify "pull request" "open a pr" " pr "
[ $fail = 0 ] && ok "entry skills carry canonical user phrasings" || true

echo "== install/uninstall roundtrip =="
# Prove the two lifecycle deliverables stay honest together: a clean HOME installs, links resolve, a
# planted foreign skill is left alone, and bd-uninstall removes only ours.
rt="$(mktemp -d)"
mkdir -p "$rt/.claude/skills/review"; printf 'not ours\n' > "$rt/.claude/skills/review/SKILL.md"
if HOME="$rt" "$ROOT/install.sh" --host claude >/dev/null 2>&1 \
   && [ -L "$rt/.claude/skills/packaging" ] \
   && [ -f "$rt/.claude/skills/.better-dev-install" ] \
   && [ ! -L "$rt/.claude/skills/review" ] \
   && HOME="$rt" "$ROOT/scripts/bd-uninstall" global --host claude --yes >/dev/null 2>&1 \
   && [ ! -e "$rt/.claude/skills/packaging" ] \
   && [ ! -f "$rt/.claude/skills/.better-dev-install" ] \
   && [ -f "$rt/.claude/skills/review/SKILL.md" ]; then
  ok "install links resolve, uninstall cleans ours, foreign skill survives"
else
  bad "install/uninstall roundtrip"
fi
rm -rf "$rt"

echo
[ $fail = 0 ] && echo "package-check: PASS ($(ls skills/ | wc -l | tr -d ' ') skills)" || { echo "package-check: FAIL"; exit 1; }
