# hosts/claude — better-dev adapter for Claude Code.
#
# Claude Code auto-discovers every SKILL.md found under its global skills dir, one namespace level deep
# (better-dev/<skill>/SKILL.md), so linking this clone's skills/ dir in as `better-dev` exposes them all.
# Sourced by install.sh, which reads these four variables. Adding a host = drop a sibling file like this.
bd_host_name="claude"
bd_host_display="Claude Code"
bd_host_cli="claude"                        # PATH probe for --host auto
bd_host_skills_dir="$HOME/.claude/skills"   # native global skills dir
