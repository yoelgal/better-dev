{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/bd-session-start\"",
            "commandWindows": "if (Get-Command bash -ErrorAction SilentlyContinue) { bash \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\bd-session-start\" }",
            "async": false,
            "timeout": 5,
            "statusMessage": "Checking for better-dev practices..."
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/bd-graphify-seed-worktree\"",
            "commandWindows": "if (Get-Command bash -ErrorAction SilentlyContinue) { bash \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\bd-graphify-seed-worktree\" }",
            "async": false,
            "timeout": 10,
            "statusMessage": "graphify-wrapper: checking worktree graphs"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/bd-graphify-refresh-stale\"",
            "commandWindows": "if (Get-Command bash -ErrorAction SilentlyContinue) { bash \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\bd-graphify-refresh-stale\" }",
            "async": false,
            "timeout": 10,
            "statusMessage": "graphify-wrapper: checking graph freshness"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/bd-subagent-start\"",
            "commandWindows": "if (Get-Command bash -ErrorAction SilentlyContinue) { bash \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\bd-subagent-start\" }",
            "async": false,
            "timeout": 5,
            "statusMessage": "Checking for better-dev practices..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/bd-guard\" check-bash",
            "commandWindows": "if (Get-Command bash -ErrorAction SilentlyContinue) { bash \"$env:CLAUDE_PLUGIN_ROOT\\scripts\\bd-guard\" check-bash }",
            "async": false,
            "timeout": 5,
            "statusMessage": "Checking guardrails..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/bd-guard\" check-edit",
            "commandWindows": "if (Get-Command bash -ErrorAction SilentlyContinue) { bash \"$env:CLAUDE_PLUGIN_ROOT\\scripts\\bd-guard\" check-edit }",
            "async": false,
            "timeout": 5,
            "statusMessage": "Checking guardrails..."
          }
        ]
      }
    ]
  }
}
